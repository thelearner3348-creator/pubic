local function updateButtonState(btn, stroke, state, baseText)
    if state then
        btn.BackgroundColor3 = Color3.fromRGB(32, 45, 38)
        btn.TextColor3 = Color3.fromRGB(0, 255, 150)
        stroke.Color = Color3.fromRGB(0, 120, 70)
        btn.Text = baseText .. ": ON"
    else
        btn.BackgroundColor3 = Color3.fromRGB(28, 28, 33)
        btn.TextColor3 = Color3.fromRGB(180, 180, 180)
        stroke.Color = Color3.fromRGB(40, 40, 48)
        btn.Text = baseText .. ": OFF"
    end
end

