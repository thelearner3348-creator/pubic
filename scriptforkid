local function addTeamToggleRow(key, displayName, index, initialColor)
    teamEnabled[key] = true
    teamColors[key] = initialColor
    teamColorIndex[key] = 1

    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, -4, 0, TEAM_ROW_HEIGHT - 4)
    row.Position = UDim2.new(0, 0, 0, (index - 1) * TEAM_ROW_HEIGHT)
    row.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
    row.BorderSizePixel = 0
    row.Parent = teamScroll

    local rc = Instance.new("UICorner")
    rc.CornerRadius = UDim.new(0, 4)
    rc.Parent = row

    local swatch = Instance.new("TextButton")
    swatch.Size = UDim2.new(0, 16, 0, 16)
    swatch.Position = UDim2.new(0, 6, 0.5, -8)
    swatch.BackgroundColor3 = initialColor
    swatch.Text = ""
    swatch.Parent = row

    local sc = Instance.new("UICorner")
    sc.CornerRadius = UDim.new(0, 4)
    sc.Parent = swatch

    swatch.MouseButton1Click:Connect(function()
        teamColorIndex[key] = (teamColorIndex[key] % #COLOR_PALETTE) + 1
        local newColor = COLOR_PALETTE[teamColorIndex[key]]
        teamColors[key] = newColor
        swatch.BackgroundColor3 = newColor
        refreshAll()
    end)

    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(1, -34, 1, 0)
    toggle.Position = UDim2.new(0, 30, 0, 0)
    toggle.BackgroundTransparency = 1
    toggle.TextColor3 = Color3.fromRGB(220, 220, 225)
    toggle.Font = Enum.Font.Gotham
    toggle.TextSize = 12
    toggle.TextXAlignment = Enum.TextXAlignment.Left
    toggle.Text = "✓  " .. displayName
    toggle.Parent = row

    toggle.MouseButton1Click:Connect(function()
        teamEnabled[key] = not teamEnabled[key]
        if teamEnabled[key] then
            toggle.Text = "✓  " .. displayName
            toggle.TextColor3 = Color3.fromRGB(220, 220, 225)
        else
            toggle.Text = "X  " .. displayName
            toggle.TextColor3 = Color3.fromRGB(120, 120, 130)
        end
        refreshAll()
    end)
end

for i, team in ipairs(teamList) do
