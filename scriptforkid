local function makeToggleButton(parent, name, yPos, text, activeInit)
    local button = Instance.new("TextButton")
    button.Name = name
    button.Size = UDim2.new(1, -20, 0, 30)
    button.Position = UDim2.new(0, 10, 0, yPos)
    button.BackgroundColor3 = activeInit and Color3.fromRGB(32, 45, 38) or Color3.fromRGB(28, 28, 33)
    button.TextColor3 = activeInit and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(180, 180, 180)
    button.Font = Enum.Font.GothamBold
    button.TextSize = 13
    button.Text = text
    button.Parent = parent

    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, 6)
    c.Parent = button
    
    local s = Instance.new("UIStroke")
    s.Color = activeInit and Color3.fromRGB(0, 120, 70) or Color3.fromRGB(40, 40, 48)
    s.Thickness = 1
    s.Parent = button

    return button, s
end

