local function updateToggle()
	if walkflinging then
		Toggle.Text = "WalkFling: ON"
		Toggle.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
		StatusLabel.Text = "Status: Flinging Active"
		if LocalPlayer.Character then
			startWalkFling(LocalPlayer.Character)
		end
	else
		Toggle.Text = "WalkFling: OFF"
		Toggle.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
		StatusLabel.Text = "Status: Idle"
		if LocalPlayer.Character then
			local Root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
			if Root then
				Root.Velocity = Vector3.zero
			end
		end
	end
end

-- Hover effect
local function addHoverEffect(button, color)
	button.MouseEnter:Connect(function()
		TweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = color:Lerp(Color3.fromRGB(255,255,255), 0.1)}):Play()
	end)
	button.MouseLeave:Connect(function()
		TweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = color}):Play()
	end)
end

addHoverEffect(Toggle, Color3.fromRGB(170, 0, 0))
addHoverEffect(CloseButton, Color3.fromRGB(170, 0, 0))

Toggle.MouseButton1Click:Connect(function()
	walkflinging = not walkflinging
	updateToggle()
end)

CloseButton.MouseButton1Click:Connect(function()
	ScreenGui:Destroy()
end)

LocalPlayer.CharacterAdded:Connect(function(char)
	if walkflinging then
		startWalkFling(char)
	end
end)

-- Initial update
updateToggle()

